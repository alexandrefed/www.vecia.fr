---
/**
 * Alexandre's Linktree / QR Landing Page
 *
 * Standalone card-style page optimized for mobile QR scans.
 * No nav/footer — clean card layout.
 * Used at Global Industrie trade show (March-April 2026).
 */

import CardLayout from '../layouts/CardLayout.astro';

const lang = 'fr';
const phone = '+33 6 51 16 07 50';

const pageTitle = 'Alexandre Fedotov — Vecia';
const pageDescription = 'Co-Fondateur de Vecia. IA & Automatisation pour l\'industrie. Prenez contact.';

// vCard data (for download button)
const vCardData = [
  'BEGIN:VCARD',
  'VERSION:3.0',
  'N:Fedotov;Alexandre;;;',
  'FN:Alexandre Fedotov',
  'ORG:Vecia',
  'TITLE:Co-Fondateur',
  `TEL;TYPE=CELL:${phone.replace(/\s/g, '')}`,
  'EMAIL;TYPE=WORK:alexandre.fedotov@vecia.fr',
  'URL:https://vecia.fr',
  'URL;TYPE=LinkedIn:https://www.linkedin.com/in/alexandre-fedotov',
  'END:VCARD'
].join('\n');

const links = [
  {
    title: 'Audit IA Gratuit',
    subtitle: 'Évaluez votre maturité numérique en 40 min',
    url: 'https://audit.vecia.fr',
    icon: 'checkmark-badge-01',
    gradient: 'from-primary to-secondary',
    primary: true,
  },
  {
    title: 'Bilan IA Express',
    subtitle: 'Recevez votre diagnostic IA en 5 min par email',
    url: 'https://vecia.fr/bilan',
    icon: 'magic-wand-01',
    gradient: 'from-accent1 to-primary',
    primary: false,
  },
  {
    title: 'Prendre rendez-vous',
    subtitle: '30 min de consultation gratuite',
    url: 'https://vecia.fr/rdv',
    icon: 'clock-02',
    gradient: 'from-secondary to-accent2',
    primary: false,
  },
  {
    title: 'Découvrir Vecia',
    subtitle: 'Notre site web',
    url: 'https://vecia.fr',
    icon: 'rocket-01',
    gradient: 'from-accent2 to-primary',
    primary: false,
  },
];
---

<CardLayout title={pageTitle} description={pageDescription} lang={lang}>
  <div class="min-h-screen bg-gradient-to-br from-background via-accent3 to-background flex items-center justify-center p-4 py-8">
    <div class="w-full max-w-md">

      <!-- Profile Card -->
      <div class="text-center mb-8">
        <!-- Logo -->
        <div class="mb-4">
          <img
            src="/vecia_logo_long_contour.png"
            alt="Vecia"
            class="h-10 mx-auto"
          />
        </div>

        <!-- Avatar / Photo placeholder -->
        <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg shadow-primary/30">
          <span class="text-white text-3xl font-display font-bold">AF</span>
        </div>

        <!-- Name & Title -->
        <h1 class="text-2xl font-display font-bold text-text">
          Alexandre Fedotov
        </h1>
        <p class="text-muted text-sm mt-1">Co-Fondateur — Vecia</p>
        <p class="text-primary font-medium text-sm mt-2">
          Automatisez vos processus
        </p>
      </div>

      <!-- CTA Links -->
      <div class="space-y-3 mb-8">
        {links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'group block w-full rounded-xl p-4 transition-all duration-300',
              'hover:shadow-xl hover:-translate-y-0.5',
              link.primary
                ? 'bg-gradient-to-r from-primary to-secondary text-white shadow-lg shadow-primary/30'
                : 'bg-white border border-gray-200 shadow-sm hover:border-primary/30'
            ]}
          >
            <div class="flex items-center gap-4">
              <div class:list={[
                'w-11 h-11 rounded-lg flex items-center justify-center flex-shrink-0 text-xl',
                link.primary
                  ? 'bg-white/20'
                  : `bg-gradient-to-br ${link.gradient} text-white`
              ]}>
                <i class={`hgi-stroke hgi-${link.icon}`} aria-hidden="true"></i>
              </div>
              <div class="flex-1 min-w-0">
                <p class:list={[
                  'font-display font-semibold text-sm',
                  link.primary ? 'text-white' : 'text-text'
                ]}>
                  {link.title}
                </p>
                <p class:list={[
                  'text-xs mt-0.5',
                  link.primary ? 'text-white/80' : 'text-muted'
                ]}>
                  {link.subtitle}
                </p>
              </div>
              <i class:list={[
                'hgi-stroke hgi-arrow-right-01 text-sm flex-shrink-0 group-hover:translate-x-1 transition-transform',
                link.primary ? 'text-white/70' : 'text-muted'
              ]} aria-hidden="true"></i>
            </div>
          </a>
        ))}
      </div>

      <!-- Contact Actions -->
      <div class="flex gap-3 mb-6">
        <!-- Save Contact (vCard) -->
        <button
          id="save-contact-btn"
          class="flex-1 flex items-center justify-center gap-2 bg-white border border-gray-200 rounded-xl py-3 px-4 text-sm font-semibold text-text hover:border-primary/30 hover:shadow-md transition-all duration-300"
        >
          <i class="hgi-stroke hgi-user-add-01 text-lg text-primary" aria-hidden="true"></i>
          Enregistrer le contact
        </button>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/alexandre-fedotov"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-12 h-12 bg-[#0A66C2] rounded-xl text-white hover:bg-[#004182] transition-colors shadow-sm"
          aria-label="LinkedIn"
        >
          <i class="hgi-stroke hgi-linkedin-01 text-xl" aria-hidden="true"></i>
        </a>
      </div>

      <!-- Direct Contact -->
      <div class="flex gap-3 mb-8">
        <a
          href="mailto:alexandre.fedotov@vecia.fr"
          class="flex-1 flex items-center justify-center gap-2 bg-white/60 backdrop-blur-sm rounded-xl py-2.5 px-3 text-xs text-muted hover:text-primary hover:bg-white transition-all"
        >
          <i class="hgi-stroke hgi-mail-01 text-base" aria-hidden="true"></i>
          Email
        </a>
        <a
          href={`tel:${phone.replace(/\s/g, '')}`}
          class="flex-1 flex items-center justify-center gap-2 bg-white/60 backdrop-blur-sm rounded-xl py-2.5 px-3 text-xs text-muted hover:text-primary hover:bg-white transition-all"
        >
          <i class="hgi-stroke hgi-call text-base" aria-hidden="true"></i>
          Appeler
        </a>
      </div>

      <!-- Footer badge -->
      <div class="text-center">
        <p class="text-xs text-muted/50">
          Global Industrie 2026 — Paris Nord Villepinte
        </p>
      </div>

    </div>
  </div>

  <!-- vCard download script -->
  <script define:vars={{ vCardData }}>
    document.getElementById('save-contact-btn')?.addEventListener('click', () => {
      const blob = new Blob([vCardData], { type: 'text/vcard;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'Alexandre-Fedotov-Vecia.vcf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  </script>
</CardLayout>
